  "description": "React components for SSB Designsystem",
  "license": "MIT",
  "author": "Statistics Norway",
  "repository": {
    "type": "git",
    "url": "https://github.com/statisticsnorway/ssb-designsystem.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
