{
  "name": "@statisticsnorway/design-react",
  "version": "0.0.1",
  "description": "React components for SSB’s design system, based on Digdir Designsystemet",
  "author": "Statistics Norway (SSB)",
  "repository": {
    "type": "git",
    "url": "https://github.com/statisticsnorway/ssb-designsystem.git"
  },
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && vite build"
  },
  "peerDependencies": {
    "react": ">=18.3.1 || ^19.0.0",
    "react-dom": ">=18.3.1 || ^19.0.0"
  },
  "dependencies": {
    "@digdir/designsystemet-react": "^1.13.3",
    "@digdir/designsystemet-types": "^1.13.3",
    "@navikt/aksel-icons": "^8.10.3",
    "@statisticsnorway/design-css": "workspace:^"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "react": "19.2.5",
    "react-dom": "19.2.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
