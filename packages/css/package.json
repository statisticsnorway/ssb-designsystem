{
  "name": "@statisticsnorway/design-css",
  "version": "0.0.1",
  "description": "CSS entry point for SSB’s design system with Digdir base styles, SSB theme, and fonts",
  "license": "MIT",
  "author": "Statistics Norway",
  "repository": {
    "type": "git",
    "url": "https://github.com/statisticsnorway/ssb-designsystem.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/types.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE-ROBOTO"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./types.d.ts",
        "default": "./src/index.css"
      },
      "types": "./dist/types.d.ts",
      "default": "./dist/src/index.css"
    },
    "./index.css": {
      "development": {
        "types": "./types.d.ts",
        "default": "./src/index.css"
      },
      "types": "./dist/types.d.ts",
      "default": "./dist/src/index.css"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm clean && mkdir -p dist && cp -R src dist/src && cp types.d.ts dist/types.d.ts"
  },
  "dependencies": {
    "@digdir/designsystemet-css": "^1.14.0",
    "@statisticsnorway/design-theme": "workspace:^"
  }
}
