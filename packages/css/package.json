{
  "name": "@statisticsnorway/design-css",
  "version": "0.0.1",
  "type": "module",
  "description": "CSS for SSBs designsystem",
  "author": "Statistics Norway",
  "license": "MIT",
  "private": true,
  "types": "./dist/types.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "development": {
        "types": "./types.d.ts",
        "default": "./src/index.css"
      },
      "types": "./dist/types.d.ts",
      "default": "./dist/src/index.css"
    },
    "./index.css": {
      "development": {
        "types": "./types.d.ts",
        "default": "./src/index.css"
      },
      "types": "./dist/types.d.ts",
      "default": "./dist/src/index.css"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && mkdir -p dist && cp -R src dist/src && cp types.d.ts dist/types.d.ts"
  },
  "dependencies": {
    "@digdir/designsystemet-css": "^1.13.3",
    "@statisticsnorway/design-theme": "workspace:^"
  }
}
