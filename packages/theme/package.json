{
  "name": "@statisticsnorway/design-theme",
  "version": "0.0.1",
  "type": "module",
  "description": "Predefined themes for the SSB (Statistics Norway) design system",
  "license": "MIT",
  "author": "Statistics Norway",
  "repository": {
    "type": "git",
    "url": "https://github.com/statisticsnorway/ssb-designsystem.git"
  },
  "files": [
    "types.d.ts",
    "brand/**",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./types.d.ts",
      "default": "./brand/ssb.css"
    },
    "./ssb.css": {
      "types": "./types.d.ts",
      "default": "./brand/ssb.css"
    },
    "./*": {
      "types": "./types.d.ts",
      "default": "./brand/*"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {}
}
