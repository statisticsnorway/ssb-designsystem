{
  "$schema": "node_modules/@digdir/designsystemet/dist/config.schema.json",
  "outDir": "./design-tokens",
  "themes": {
    "ssb": {
      "colors": {
        "main": {
          "accent": "#00824D"
        },
        "support": {
          "brand1": "#274247",
          "brand2": "#9272FC"
        },
        "neutral": "#24272B"
      },
      "overrides": {
        "colors": {
          "accent": {
            "background-tinted": {
              "light": "#ecf6f2"
            }
          }
        }
      },
      "borderRadius": 4,
      "typography": {
        "fontFamily": "Roboto, sans-serif"
      }
    }
  }
}
