{
  "name": "ssb-designsystem",
  "author": "Statistics Norway (SSB)",
  "repository": {
    "type": "git",
    "url": "https://github.com/statisticsnorway/ssb-designsystem.git"
  },
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "tokens:create": "designsystemet tokens create --clean",
    "tokens:inject": "node scripts/inject-token-overrides.ts",
    "tokens:build": "designsystemet tokens build --clean -o ./packages/css/theme",
    "tokens:update": "pnpm tokens:create && pnpm tokens:inject && pnpm tokens:build",
    "storybook": "pnpm --filter @statisticsnorway/storybook dev",
    "storybook:build": "pnpm --filter @statisticsnorway/storybook build-storybook",
    "build:css": "pnpm --filter @statisticsnorway/design-css build",
    "build:react": "pnpm --filter @statisticsnorway/design-react build",
    "build": "pnpm build:css && pnpm build:react",
    "test": "pnpm --filter @statisticsnorway/design-react test:run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@digdir/designsystemet": "^1.18.0",
    "@types/node": "^26.0.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.3"
  }
}
