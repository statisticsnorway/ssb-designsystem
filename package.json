{
  "name": "ssb-designsystem",
  "author": "Statistics Norway (SSB)",
  "repository": {
    "type": "git",
    "url": "https://github.com/statisticsnorway/ssb-designsystem.git"
  },
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "tokens:create": "designsystemet tokens create",
    "tokens:build": "designsystemet tokens build --clean -o ./packages/theme/brand",
    "tokens:update": "rm -rf design-tokens && pnpm tokens:create && pnpm tokens:build",
    "storybook": "pnpm --filter @ssb/storybook storybook",
    "storybook:build": "pnpm --filter @ssb/storybook build-storybook",
    "build:css": "pnpm --filter @statisticsnorway/design-css build",
    "build:react": "pnpm --filter @statisticsnorway/design-react build",
    "build": "pnpm build:css && pnpm build:react",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@digdir/designsystemet": "^1.13.3",
    "prettier": "^3.8.3"
  }
}
