{
  "name": "ssb-designsystem",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "tokens:create": "designsystemet tokens create",
    "tokens:build": "designsystemet tokens build --clean -o ./packages/theme/generated",
    "tokens:update": "npm run tokens:create && npm run tokens:build",
    "storybook": "npm run storybook -w apps/storybook"
  },
  "devDependencies": {
    "@digdir/designsystemet": "^1.13.0"
  }
}
