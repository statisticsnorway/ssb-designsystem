{
  "name": "ssb-designsystem",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "tokens:create": "designsystemet tokens create",
    "tokens:build": "designsystemet tokens build --clean -o ./packages/theme/brand",
    "tokens:update": "rm -rf design-tokens && pnpm run tokens:create && pnpm run tokens:build",
    "storybook": "pnpm --filter @ssb/storybook storybook",
    "build:css": "pnpm --filter @statisticsnorway/design-css build",
    "build:react": "pnpm --filter @statisticsnorway/design-react build",
    "build": "pnpm run build:css && pnpm run build:react"
  },
  "devDependencies": {
    "@digdir/designsystemet": "^1.13.3",
    "prettier": "^3.8.3"
  }
}
