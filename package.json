{
  "name": "ssb-designsystem",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css,scss}\"",
    "tokens:create": "designsystemet tokens create",
    "tokens:build": "designsystemet tokens build --clean -o ./packages/theme/brand",
    "tokens:update": "npm run tokens:create && npm run tokens:build",
    "storybook": "npm run storybook -w apps/storybook"
  },
  "devDependencies": {
    "@digdir/designsystemet": "^1.13.2",
    "prettier": "^3.8.3"
  }
}
